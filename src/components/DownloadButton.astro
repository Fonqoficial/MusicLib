---
interface Props {
  scoreId: string;
  scoreTitle: string;
  currentDownloads: number;
}

const { scoreId, scoreTitle, currentDownloads } = Astro.props;
---

<div class="download-container">
  <!-- Cambiado id por class y añadido data-attributes -->
  <button
    class="download-btn w-full bg-primary-600 text-white py-4 rounded-lg font-semibold hover:bg-primary-700 transition-colors flex items-center justify-center gap-2 shadow-lg"
    data-score-id={scoreId}
    data-score-title={scoreTitle}
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
    </svg>
    <span class="btn-text">Descargar PDF</span>
  </button>

  <div class="mt-2 text-center">
    <p class="text-sm text-gray-600">
      <span class="download-counter">{currentDownloads}</span> descargas
    </p>
  </div>

  <div class="progress-bar hidden mt-3">
    <div class="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
      <div class="progress-fill bg-primary-600 h-2 transition-all duration-300" style="width: 0%"></div>
    </div>
    <p class="text-xs text-gray-600 mt-1 text-center">
      <span class="progress-text">Preparando descarga...</span>
    </p>
  </div>
</div>

<script>
  // Usamos delegación de eventos para manejar múltiples botones eficientemente
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.download-btn') as HTMLButtonElement;
    if (!btn) return;

    const container = btn.closest('.download-container');
    if (!container) return;

    const btnText = btn.querySelector('.btn-text');
    const counter = container.querySelector('.download-counter');
    const progressBar = container.querySelector('.progress-bar');
    const progressFill = container.querySelector('.progress-fill') as HTMLDivElement;
    const progressText = container.querySelector('.progress-text');

    const scoreId = btn.getAttribute('data-score-id');
    const scoreTitle = btn.getAttribute('data-score-title');

    if (!scoreId || !btnText) return;

    // Estado de carga
    btn.disabled = true;
    btn.classList.add('opacity-50', 'cursor-not-allowed');
    const originalHTML = btnText.innerHTML;
    btnText.innerHTML = 'Preparando...';
    progressBar?.classList.remove('hidden');

    const updateProgress = (percent: number, text: string) => {
      if (progressFill) progressFill.style.width = `${percent}%`;
      if (progressText) progressText.textContent = text;
    };

    try {
      updateProgress(10, 'Conectando con servidor...');
      await new Promise(r => setTimeout(r, 300));
      
      updateProgress(30, 'Verificando archivo...');
      const infoResponse = await fetch(`/api/download-info/${scoreId}`);
      if (!infoResponse.ok) throw new Error('Error de servidor');
      const info = await infoResponse.json();

      updateProgress(60, 'Generando enlace seguro...');
      await new Promise(r => setTimeout(r, 300));

      updateProgress(90, 'Iniciando descarga...');
      window.location.href = info.downloadUrl;

      updateProgress(100, '¡Descarga iniciada!');

      // Actualizar contador
      fetch(`/api/download`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ scoreId })
      })
      .then(res => res.json())
      .then(data => {
        if (counter && data.downloads) counter.textContent = data.downloads.toString();
      });

      setTimeout(() => {
        btnText.innerHTML = originalHTML;
        btn.disabled = false;
        btn.classList.remove('opacity-50', 'cursor-not-allowed');
        progressBar?.classList.add('hidden');
      }, 2000);

    } catch (error) {
      btnText.innerHTML = 'Error';
      alert('No se pudo descargar el archivo.');
      btn.disabled = false;
      btn.classList.remove('opacity-50', 'cursor-not-allowed');
    }
  });
</script>
