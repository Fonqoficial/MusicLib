---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = 'Biblioteca digital de partituras musicales. Encuentra y descarga partituras de dominio público.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  
  <!-- CORREGIDO: Ruta absoluta y nombre sin espacios -->
  <link rel="shortcut icon" href="/logo-noted.png" type="image/x-icon">
  <title>{title} | Noted Library</title>
</head>
<body class="min-h-screen flex flex-col bg-slate-50 text-slate-900"> <!-- Añadido fondo suave -->
  <slot name="header" />
  <main class="flex-1">
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>
