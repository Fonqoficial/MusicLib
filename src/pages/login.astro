---
import Layout from '@/layouts/Layout.astro';

const error = Astro.url.searchParams.get('error');
const message = Astro.url.searchParams.get('message');
---

<Layout title="Iniciar Sesión - MusicLib">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      
      <!-- Header -->
      <div class="text-center">
        <a href="/" class="inline-block">
          <div class="flex items-center justify-center gap-2 text-3xl font-bold text-primary-600">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                    d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
            </svg>
            <span>MusicLib</span>
          </div>
        </a>
        <h2 class="mt-6 text-3xl font-bold text-gray-900">
          Iniciar Sesión
        </h2>
        <p class="mt-2 text-sm text-gray-600">
          O{' '}
          <a href="/register" class="font-medium text-primary-600 hover:text-primary-500">
            crea una cuenta nueva
          </a>
        </p>
      </div>

      <!-- Mensajes -->
      {error && (
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg">
          {error === 'unauthorized' && 'No tienes permisos para acceder a esta página'}
          {error === 'session_expired' && 'Tu sesión ha expirado, por favor inicia sesión nuevamente'}
        </div>
      )}

      {message && (
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg">
          {message}
        </div>
      )}

      <!-- Formulario -->
      <form id="login-form" class="mt-8 space-y-6">
        <div class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Correo electrónico
            </label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              placeholder="tu@ejemplo.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              Contraseña
            </label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="appearance-none rounded-lg relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              placeholder="••••••••"
            />
          </div>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input
              id="remember-me"
              name="remember-me"
              type="checkbox"
              class="h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded"
            />
            <label for="remember-me" class="ml-2 block text-sm text-gray-900">
              Recordarme
            </label>
          </div>

          <div class="text-sm">
            <a href="/reset-password" class="font-medium text-primary-600 hover:text-primary-500">
              ¿Olvidaste tu contraseña?
            </a>
          </div>
        </div>

        <!-- Error message -->
        <div id="error-message" class="hidden text-red-600 text-sm text-center p-3 bg-red-50 rounded-lg"></div>

        <!-- Loading message -->
        <div id="loading-message" class="hidden text-blue-600 text-sm text-center p-3 bg-blue-50 rounded-lg">
          Iniciando sesión...
        </div>

        <!-- Submit button -->
        <button
          type="submit"
          id="submit-btn"
          class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
        >
          Iniciar Sesión
        </button>
      </form>

      <div class="text-center text-sm text-gray-600">
        <a href="/" class="hover:text-primary-600">
          ← Volver al inicio
        </a>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { getBrowserClient } from '@/lib/supabase';

  const supabase = getBrowserClient();
  
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorDiv = document.getElementById('error-message');
  const loadingDiv = document.getElementById('loading-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    // Mostrar loading
    errorDiv?.classList.add('hidden');
    loadingDiv?.classList.remove('hidden');
    submitBtn.disabled = true;

    try {
      const { data, error } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (error) throw error;

      // Obtener rol del usuario
      const { data: roleData } = await supabase
        .from('user_roles')
        .select('role')
        .eq('user_id', data.user.id)
        .single();

      // Determinar a dónde redirigir
      const params = new URLSearchParams(window.location.search);
      const redirect = params.get('redirect');
      
      let destination = '/';
      
      if (redirect) {
        destination = redirect;
      } else if (roleData?.role === 'admin') {
        destination = '/admin';
      } else {
        destination = '/account';
      }

      // Esperar un momento para que la sesión se guarde
      await new Promise(resolve => setTimeout(resolve, 500));

      // Redirigir
      window.location.href = destination;

    } catch (error) {
      console.error('Login error:', error);
      
      loadingDiv?.classList.add('hidden');
      submitBtn.disabled = false;
      
      if (errorDiv) {
        errorDiv.textContent = error instanceof Error 
          ? error.message 
          : 'Error al iniciar sesión. Verifica tus credenciales.';
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>